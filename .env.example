# Pulse Dashboard — Environment Variables
# This project runs entirely client-side. No backend setup required.
# These variables are optional and only needed if you connect a backend.

# Database (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/pulse

# API Base URL (optional)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Authentication (optional)
# NEXT_PUBLIC_AUTH_ENABLED=false
# AUTH_SECRET=your-secret-here

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=UA-XXXXX
